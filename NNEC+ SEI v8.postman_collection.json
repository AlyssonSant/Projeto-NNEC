              "var hashProcesso = pm.collectionVariables.get('INFRA_HASH_PROCESSO') || '';",
              "var hash = pm.collectionVariables.get('INFRA_HASH_PROC_VIS');",
              "var id = pm.collectionVariables.get('ID_PROCEDIMENTO');",
              "var unidade = pm.collectionVariables.get('INFRA_UNIDADE');",
              "console.log('[05 PRE] INFRA_HASH_PROCESSO:', hashProcesso);",
              "console.log('[05 PRE] INFRA_HASH_PROC_VIS:', hash);",
              "pm.request.headers.upsert({key: 'Cookie', value: 'PHPSESSID=' + s + (r ? '; ROUTEID=' + r : '') + '; SIP_U_GOVMG_SEI=24; GOVMG_SEI_60905732308_menu_mostrar=S'});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "console.log('[05] STATUS: ' + pm.response.status);",
              "const rawHtml = pm.response.text();",
              "const html = rawHtml.replace(/&amp;/gi,'&').replace(/&quot;/gi,'\"').replace(/&#39;/gi,\"'\").replace(/&#x27;/gi,\"'\");",
              "console.log('[05] HTML inicio: ' + rawHtml.substring(0, 300));",
              "var mAction = html.match(/action=[\"'][^\"']*controlador\\.php[^\"']*acesso_externo_disponibilizar[^\"']*infra_hash=([a-fA-F0-9]+)/i);",
              "if (!mAction) mAction = html.match(/action=[\"'][^\"']*infra_hash=([a-fA-F0-9]+)[^\"']*acesso_externo_disponibilizar/i);",
              "if (mAction) { pm.collectionVariables.set('INFRA_HASH_FORM', mAction[1]); console.log('[05] INFRA_HASH_FORM:', mAction[1]); }",
              "else { console.log('[05] INFRA_HASH_FORM nao encontrado. Hashes: ' + JSON.stringify((html.match(/infra_hash=[a-fA-F0-9]+/g)||[]).slice(0,8))); }",
              "var m1 = html.match(/name=[\"']hdnInfraItens[\"'][^>]*value=[\"']([^\"']*)[\"']/i)||html.match(/value=[\"']([^\"']*)[\"'][^>]*name=[\"']hdnInfraItens[\"']/i);",
              "if (m1) { pm.collectionVariables.set('HDN_INFRA_ITENS', m1[1]); }",
              "var m2 = html.match(/name=[\"']hdnInfraItensHash[\"'][^>]*value=[\"']([^\"']*)[\"']/i)||html.match(/value=[\"']([^\"']*)[\"'][^>]*name=[\"']hdnInfraItensHash[\"']/i);",
              "if (m2) { pm.collectionVariables.set('HDN_INFRA_ITENS_HASH', m2[1]); }",
              "var m3 = html.match(/name=[\"']hdnInfraNroItens[\"'][^>]*value=[\"']([^\"']*)[\"']/i)||html.match(/value=[\"']([^\"']*)[\"'][^>]*name=[\"']hdnInfraNroItens[\"']/i);",
              "if (m3) { pm.collectionVariables.set('HDN_INFRA_NRO_ITENS', m3[1]); }",
              "var m4 = html.match(/contato_auto_completar_acesso_externo[^\"'<>]*infra_hash=([a-fA-F0-9]+)/i)||html.match(/infra_hash=([a-fA-F0-9]+)[^\"'<>]*contato_auto_completar_acesso_externo/i);",
              "if (m4) { pm.collectionVariables.set('INFRA_HASH_AJAX_1', m4[1]); }",
              "var m5 = html.match(/acesso_externo_dados_destinatario[^\"'<>]*infra_hash=([a-fA-F0-9]+)/i)||html.match(/infra_hash=([a-fA-F0-9]+)[^\"'<>]*acesso_externo_dados_destinatario/i);",
              "if (m5) { pm.collectionVariables.set('INFRA_HASH_AJAX_2', m5[1]); }",
              "var m6 = html.match(/option[^>]+value=[\"']([^\"']*alysson[^\"']*)[\"']/i);",
              "if (!m6) { var selBlock = html.match(/name=[\"']selEmailUnidade[\"'][\\s\\S]{0,800}?<\\/select>/i); if (selBlock) { var fo = selBlock[0].match(/option[^>]+value=[\"']([^\"']+)[\"']/i); if (fo) m6=fo; } }",
              "if (m6) { pm.collectionVariables.set('SEL_EMAIL_UNIDADE', m6[1]); }",
              "pm.test('200 ok', function() { pm.response.to.have.status(200); });",
              "pm.test('INFRA_HASH_FORM ok', function() { pm.expect(pm.collectionVariables.get('INFRA_HASH_FORM')).to.not.be.empty; });"
            ]
          }
        }
      ],
