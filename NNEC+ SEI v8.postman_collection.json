    {
      "name": "03c - GET procedimento_trabalhar (captura hash acesso_externo)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var s = pm.collectionVariables.get('PHPSESSID_SEI');",
              "var r = pm.collectionVariables.get('ROUTEID') || '';",
              "var hash = pm.collectionVariables.get('INFRA_HASH_PROC_TRAB');",
              "var id = pm.collectionVariables.get('ID_PROCEDIMENTO');",
              "var unidade = pm.collectionVariables.get('INFRA_UNIDADE');",
              "console.log('[03c PRE] INFRA_HASH_PROC_TRAB:', hash);",
              "pm.request.url = 'https://www.sei.mg.gov.br/sei/controlador.php?acao=procedimento_trabalhar&acao_origem=procedimento_controlar&acao_retorno=procedimento_controlar&id_procedimento=' + id + '&infra_sistema=100000100&infra_unidade_atual=' + unidade + '&infra_hash=' + hash;",
              "pm.request.headers.upsert({key: 'Cookie', value: 'PHPSESSID=' + s + (r ? '; ROUTEID=' + r : '') + '; SIP_U_GOVMG_SEI=24; GOVMG_SEI_60905732308_menu_mostrar=S'});",
              "pm.request.headers.upsert({key: 'User-Agent', value: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36'});",
              "pm.request.headers.upsert({key: 'Accept', value: 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'});",
              "pm.request.headers.upsert({key: 'Referer', value: 'https://www.sei.mg.gov.br/sei/controlador.php?acao=procedimento_controlar&infra_sistema=100000100&infra_unidade_atual=' + unidade + '&infra_hash=' + hash});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "console.log('[03c] STATUS: ' + pm.response.status);",
              "pm.response.headers.all().forEach(function(h) {",
              "    if (h.key.toLowerCase() === 'set-cookie') {",
              "        var ms = h.value.match(/PHPSESSID=([^;]+)/);",
              "        if (ms) { pm.collectionVariables.set('PHPSESSID_SEI', ms[1]); }",
              "        var mr = h.value.match(/ROUTEID=([^;]+)/);",
              "        if (mr) { pm.collectionVariables.set('ROUTEID', mr[1]); }",
              "    }",
              "});",
              "var html = pm.response.text().replace(/&amp;/gi, '&');",
              "var id = pm.collectionVariables.get('ID_PROCEDIMENTO');",
              "",
              "// PRIORIDADE 1: captura hash do botao acesso_externo_gerenciar (barra de ferramentas)",
              "var mAcesso = html.match(/acao=acesso_externo_gerenciar[^\"']*?infra_hash=([a-fA-F0-9]{32,})/i);",
              "if (mAcesso) {",
              "    pm.collectionVariables.set('INFRA_HASH_PROCESSO', mAcesso[1]);",
              "    console.log('✅ [03c] INFRA_HASH_PROCESSO (acesso_externo) capturado:', mAcesso[1]);",
              "} else {",
              "    console.log('[03c] acesso_externo_gerenciar nao encontrado na barra. Logando todos os hrefs com hash:');",
              "    var allHashes = [...html.matchAll(/href=[\"']([^\"']*infra_hash=[a-fA-F0-9]{32,}[^\"']*)[\"']/gi)];",
              "    allHashes.slice(0, 5).forEach(function(m, i) { console.log('[03c] href' + i + ':', m[1].substring(0, 150)); });",
              "}",
              "",
              "// PRIORIDADE 2: captura hash do iframe src procedimento_visualizar",
              "var mVis = html.match(/src=[^>]*acao=procedimento_visualizar[^\"']*infra_hash=([a-fA-F0-9]{32,})/i);",
              "if (mVis) {",
              "    pm.collectionVariables.set('INFRA_HASH_PROC_VIS', mVis[1]);",
              "    console.log('[03c] INFRA_HASH_PROC_VIS (iframe src):', mVis[1]);",
              "} else {",
              "    console.log('[03c] iframe procedimento_visualizar nao encontrado');",
              "}",
              "",
              "pm.test('03c ok', function() { pm.expect(pm.response.code).to.be.oneOf([200, 302]); });"
            ]
          }
        }
      ],
