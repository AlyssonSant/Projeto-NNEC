    {
      "name": "01 - GET Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var sid = '', rid = '';",
              "pm.response.headers.all().forEach(function(h) {",
              "    if (h.key.toLowerCase() === 'set-cookie') {",
              "        var ms = h.value.match(/PHPSESSID=([^;]+)/);",
              "        if (ms && ms[1] !== 'deleted') sid = ms[1];",
              "        var mr = h.value.match(/ROUTEID=([^;]+)/);",
              "        if (mr) rid = mr[1];",
              "    }",
              "});",
              "if (!sid) { try { var j = pm.cookies.toObject(); if (j.PHPSESSID) sid = j.PHPSESSID; if (j.ROUTEID) rid = j.ROUTEID; } catch(e) {} }",
              "if (sid) { pm.collectionVariables.set('PHPSESSID', sid); console.log('[01] PHPSESSID:', sid); }",
              "if (rid) { pm.collectionVariables.set('ROUTEID', rid); console.log('[01] ROUTEID:', rid); }",
              "pm.test('status 200', function() { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
